// ─────────────────────────────────────────────────────────────────────────────
// Al-Fateem Academy — Headless CMS data model
//
// Derived field-for-field from the existing frontend content sources:
//   ~/sites/alfateem-web/src/lib/{site,courses,content}.ts
//
// Structured content (post bodies, section payloads) is stored as validated JSON,
// never raw HTML — the API validates shape on write and the frontend renders it as
// data, so there is no XSS surface. All schema changes ship via migrations only.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
  // native = local dev; rhel-openssl-3.0.x = Vercel's serverless runtime (Amazon Linux).
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  EDITOR
}

enum Track {
  Frontend
  Backend
  Data
  Platform
  AI
}

enum Level {
  Beginner
  Intermediate
  Advanced
}

enum SectionType {
  hero
  techMarquee
  whyUs
  coursesGrid
  graduatesWall
  blogPreview
  faq
  cta
  richText
  gallery
  stats
  testimonials
}

enum ReviewSource {
  GOOGLE
  FACEBOOK
  MANUAL
  WEBSITE
}

enum LeadStatus {
  NEW
  CONTACTED
  ENROLLED
  REJECTED
}

enum MessageStatus {
  NEW
  READ
  ARCHIVED
}

// ── Auth ─────────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         Role      @default(EDITOR)
  active       Boolean   @default(true)
  // Hash of the current refresh token — enables rotation + server-side revoke.
  // Never the token itself.
  refreshTokenHash String? @db.Text
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("users")
}

// ── Courses & lessons ────────────────────────────────────────────────────────

model Course {
  id             String   @id @default(cuid())
  slug           String   @unique
  title          String
  short          String
  track          Track
  level          Level
  duration       String
  summary        String   @db.Text
  // string[] of technologies — rendered as chips, fed into Course JSON-LD.
  stack          Json
  seoTitle       String
  seoDescription String   @db.Text
  order          Int      @default(0)
  published      Boolean  @default(true)
  lessons        Lesson[]
  batches        Batch[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([track])
  @@index([published])
  @@map("courses")
}

// A scheduled intake of a course: start date, class schedule, fee and seats. Public
// course endpoints include only published upcoming batches; the admin manages the
// full set. Seats are maintained by hand (seatsLeft) — decremented by staff as
// enrollments confirm, giving the site honest scarcity ("3 seats left").
model Batch {
  id         String   @id @default(cuid())
  courseId   String
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  startDate  DateTime
  // Human-readable class times, e.g. "Mon · Wed · Fri — 7:00–9:00 PM"
  schedule   String
  // Free text so installments/discounts fit: "Rs 4,000 / month" / "Rs 30,000 total"
  fee        String?
  seatsTotal Int?
  seatsLeft  Int?
  note       String?
  published  Boolean  @default(true)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([courseId])
  @@index([startDate])
  @@map("batches")
}

model Lesson {
  id        String   @id @default(cuid())
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title     String
  // Lesson slugs are globally unique — the frontend serves them at /lesson/<slug>/.
  slug      String   @unique
  blurb     String   @db.Text
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([courseId])
  @@map("lessons")
}

// ── Blog ─────────────────────────────────────────────────────────────────────

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  posts     Post[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories")
}

model Post {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  image       String
  excerpt     String   @db.Text
  // Publication date shown on the article; distinct from createdAt.
  date        DateTime
  readingTime String
  // Ordered array of typed blocks (p|h2|h3|ul|ol|code). Validated on write.
  body        Json
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([categoryId])
  @@index([published])
  @@map("posts")
}

// ── Events ───────────────────────────────────────────────────────────────────

model Event {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  date      DateTime
  blurb     String   @db.Text
  cover     String
  // string[] of gallery image URLs.
  images    Json
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published])
  @@map("events")
}

// ── Graduates ────────────────────────────────────────────────────────────────

model Graduate {
  id        String   @id @default(cuid())
  name      String
  image     String
  role      String?
  year      Int
  order     Int      @default(0)
  featured  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([year])
  @@map("graduates")
}

// Student / customer reviews. Imported (Google, Facebook) or entered manually in the
// admin. `approved` gates public visibility (moderation); `featured` surfaces the review
// in highlighted placements (home/about). `quote` is free text (rendered as plain text,
// never HTML) so there is no XSS surface.
model Testimonial {
  id         String       @id @default(cuid())
  author     String
  role       String?
  quote      String       @db.Text
  rating     Int          @default(5)
  source     ReviewSource @default(MANUAL)
  sourceUrl  String?
  avatar     String?
  reviewedAt DateTime?
  approved   Boolean      @default(true)
  featured   Boolean      @default(false)
  order      Int          @default(0)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([approved])
  @@index([source])
  @@map("testimonials")
}

// ── Site settings / nav / stats ──────────────────────────────────────────────

// Single-row settings document (id is pinned to "singleton" in code). Structured
// sub-objects (contact, social, media) are stored as JSON so the admin can edit
// them as a unit without a migration per field.
model SiteSetting {
  id            String   @id @default("singleton")
  name          String
  legalName     String
  tagline       String
  url           String
  founded       String
  description   String   @db.Text
  twitterHandle String
  contact       Json // { email, phones[], address{street,city,region,country} }
  social        Json // { facebook, twitter, youtube, linkedin }
  media         Json // { logo, logoSquare, ceo, graduates, eventPlaceholder, gallery, uploads }
  updatedAt     DateTime @updatedAt

  @@map("site_settings")
}

model NavItem {
  id          String   @id @default(cuid())
  label       String
  href        String
  hasMegaMenu Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("nav_items")
}

model Stat {
  id        String   @id @default(cuid())
  value     Int
  suffix    String   @default("")
  label     String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("stats")
}

// ── Pages & folds (the CMS core) ─────────────────────────────────────────────

model Page {
  id              String    @id @default(cuid())
  key             String    @unique // "home" | "about" | "contact" | ...
  title           String
  metaTitle       String?
  metaDescription String?   @db.Text
  ogImage         String?
  published       Boolean   @default(true)
  sections        Section[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("pages")
}

model Section {
  id        String      @id @default(cuid())
  pageId    String
  page      Page        @relation(fields: [pageId], references: [id], onDelete: Cascade)
  type      SectionType
  order     Int         @default(0)
  enabled   Boolean     @default(true)
  // Typed payload validated per-section-type by the section registry (DTO + schema).
  // May embed content, or hold references/filters resolved against collections
  // (e.g. coursesGrid selects Courses; graduatesWall references Graduates).
  data      Json
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([pageId, order])
  @@map("sections")
}

// ── Public form submissions ──────────────────────────────────────────────────

model RegistrationLead {
  id         String     @id @default(cuid())
  name       String
  email      String
  phone      String
  courseSlug String?
  message    String?    @db.Text
  status     LeadStatus @default(NEW)
  source     String     @default("website")
  // Marketing attribution captured client-side: { utmSource, utmMedium, utmCampaign,
  // utmTerm, utmContent, referrer, landingPage }. Keys are whitelisted server-side.
  attribution Json?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("registration_leads")
}

model ContactMessage {
  id        String        @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String        @db.Text
  status    MessageStatus @default(NEW)
  attribution Json?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("contact_messages")
}
