# ─────────────────────────────────────────────────────────────────────────────
# academy-cms-api — environment
# Copy to `.env` and fill in. `.env` is gitignored; never commit real secrets.
# The app validates every variable below at boot (src/config/env.validation.ts)
# and refuses to start if anything required is missing or malformed.
# ─────────────────────────────────────────────────────────────────────────────

# App
NODE_ENV=development
PORT=4000
# Base path is fixed at /api/v1 in code; this is only the public origin used in docs/links.
APP_URL=http://localhost:4000

# Database (MySQL). Prisma reads DATABASE_URL.
# Use a LEAST-PRIVILEGE application user in production (SELECT/INSERT/UPDATE/DELETE
# on this schema only — not root).
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://cms:cms_password@localhost:3306/academy_cms"

# These three are consumed by docker-compose to provision the MySQL container.
# Keep them in sync with DATABASE_URL above.
MYSQL_DATABASE=academy_cms
MYSQL_USER=cms
MYSQL_PASSWORD=cms_password
MYSQL_ROOT_PASSWORD=change_me_root_password

# JWT — generate strong random values, e.g. `openssl rand -base64 48`
JWT_ACCESS_SECRET=replace_with_long_random_string_min_32_chars
JWT_REFRESH_SECRET=replace_with_DIFFERENT_long_random_string_min_32_chars
JWT_ACCESS_TTL=900          # access token lifetime, seconds (15m)
JWT_REFRESH_TTL=1209600     # refresh token lifetime, seconds (14d)

# Initial ADMIN user — created idempotently by the seed. Change the password.
SEED_ADMIN_EMAIL=admin@alfateemacademy.com
SEED_ADMIN_PASSWORD=ChangeMe_Strong_Passw0rd!
SEED_ADMIN_NAME=Site Administrator

# CORS — comma-separated list of allowed frontend origins (no trailing slash).
# Include the public site and the admin app.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate limiting (global default; auth + public forms are stricter in code)
THROTTLE_TTL=60             # window, seconds
THROTTLE_LIMIT=120          # requests per window per IP

# Frontend revalidation webhook (Option A / ISR).
# When an admin publishes, the API calls FRONTEND_REVALIDATE_URL with this secret so
# the Next.js site regenerates affected pages within seconds.
FRONTEND_REVALIDATE_URL=http://localhost:3000/api/revalidate
REVALIDATE_SECRET=replace_with_shared_random_secret

# Lead email notifications (optional). Set SMTP_HOST + NOTIFY_TO to email every new
# registration/contact submission to the academy; leave unset to only log them.
# Works with any SMTP provider (Gmail app password, Brevo, Resend SMTP, Mailgun...).
#SMTP_HOST=smtp.gmail.com
#SMTP_PORT=587
#SMTP_SECURE=false
#SMTP_USER=you@gmail.com
#SMTP_PASS=your_app_password
#NOTIFY_FROM=Al-Fateem Academy <no-reply@alfateemacademy.com>
#NOTIFY_TO=admissions@alfateemacademy.com

# Swagger UI — set to false to disable /docs in production if desired.
SWAGGER_ENABLED=true
